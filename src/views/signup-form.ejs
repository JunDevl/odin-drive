<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Sign-up</title>
  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet" href="auth-form.css">
</head>

<body id="auth">
  <main class="auth">
    <h1>Sign-up</h1>
    <form action="/users" method="POST">
      <input name="fullName" id="fullName" placeholder="Full Name" required>
      <input name="username" id="username" placeholder="Username" required />
      <input name="email" id="email" placeholder="Email" type="email" required>
      <input name="password" id="password" placeholder="Password" type="password" required />
    
      <button type="submit">Sign-up</button>
    </form>
    <p>Already have an account? <a href="/log-in">Log-in!</a></p>
  </main>
</body>

</html>